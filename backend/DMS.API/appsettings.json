{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=dms_db;Username=postgres;Password=postgres"
  },
  "JwtSettings": {
    "Secret": "CHANGE_THIS_TO_A_STRONG_SECRET_KEY_MIN_32_CHARS!!",
    "Issuer": "DMS.API",
    "Audience": "DMS.Client",
    "ExpirationInMinutes": 60
  },
  "FileSettings": {
    "MaxFileSizeMB": 10,
    "AllowedExtensions": [".pdf", ".docx", ".doc", ".jpg", ".jpeg", ".png"],
    "UploadPath": "wwwroot/uploads"
  }
}
